{
  "name": "rental-system",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "wrangler pages dev -- npm run dev:web",
    "dev:web": "vite",
    "db:push": "wrangler d1 migrations apply rental-db --local",
    "db:seed": "node --experimental-strip-types prisma/seed.ts",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "npm run build && wrangler pages dev dist"
  },
  "prisma": {
    "seed": "node --experimental-strip-types prisma/seed.ts"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.8.0",
    "@prisma/adapter-d1": "^7.8.0",
    "@prisma/client": "^6.16.1",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "cookie": "^1.1.1",
    "framer-motion": "^12.40.0",
    "hono": "^4.12.26",
    "hono-sessions": "^0.8.1",
    "lucide-react": "^1.17.0",
    "prisma": "^6.16.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "recharts": "^3.8.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260621.1",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^7.2.4",
    "wrangler": "^4.103.0"
  }
}
