{
  "name": "rental-system",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "sh -c 'node --experimental-strip-types server/index.ts & vite'",
    "dev:api": "node --experimental-strip-types server/index.ts",
    "dev:web": "vite",
    "db:push": "prisma db push",
    "db:seed": "node --experimental-strip-types prisma/seed.ts",
    "db:reset": "prisma db push --force-reset && node --experimental-strip-types prisma/seed.ts",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "test:api": "node --experimental-strip-types server/api.test.ts",
    "test:pl": "node --experimental-strip-types src/reports.test.ts",
    "test:selectors": "node --experimental-strip-types src/selectors.test.ts",
    "preview": "vite preview"
  },
  "prisma": {
    "seed": "node --experimental-strip-types prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.16.1",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.17.0",
    "prisma": "^6.16.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^7.2.4"
  }
}
